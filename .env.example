# edgefinder — example environment file.
# Copy to ".env" and fill in real values, OR just `export` these in your shell.
# NOTHING here is required for the baseline backtest or the GDELT news overlay
# (GDELT is free and needs no key). These only enable OPTIONAL LLM re-scoring.

# --- Optional free LLM providers (pick ONE) ---------------------------------

# Groq — free tier, very fast. https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini — free tier. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama — fully local/offline, no key. Run `ollama serve`, then uncomment:
# USE_OLLAMA=1
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# --- Optional paid news provider (NOT required; GDELT is the free default) ---
# NEWS_API_KEY=your_news_api_key_here
